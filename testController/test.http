# @name 并发抢票1
POST http://localhost:8080/api/v1/tickets/book
Content-Type: application/x-www-form-urlencoded

userId=9001&trainId=1001&fromIndex=1&toIndex=3&seatType=2

### 15. 并发抢票2
# @name 并发抢票2
POST http://localhost:8080/api/v1/tickets/book
Content-Type: application/x-www-form-urlencoded

userId=9002&trainId=1001&fromIndex=1&toIndex=3&seatType=2

### 16. 并发抢票3
# @name 并发抢票3
POST http://localhost:8080/api/v1/tickets/book
Content-Type: application/x-www-form-urlencoded

userId=9003&trainId=1001&fromIndex=1&toIndex=3&seatType=2

###############################################
# 边界条件测试
###############################################

### 17. 起点终点相同（应该失败或返回错误）
# @name 起点终点相同
POST http://localhost:8080/api/v1/tickets/book
Content-Type: application/x-www-form-urlencoded

userId=8893&trainId=1001&fromIndex=2&toIndex=2&seatType=2

### 18. 终点小于起点（应该失败）
# @name 终点小于起点
POST http://localhost:8080/api/v1/tickets/book
Content-Type: application/x-www-form-urlencoded

userId=8894&trainId=1001&fromIndex=5&toIndex=2&seatType=2

### 19. 不存在的车次
# @name 不存在的车次
POST http://localhost:8080/api/v1/tickets/book
Content-Type: application/x-www-form-urlencoded

userId=8895&trainId=9999&fromIndex=1&toIndex=3&seatType=2

### 20. 不存在的座位类型
# @name 不存在的座位类型
POST http://localhost:8080/api/v1/tickets/book
Content-Type: application/x-www-form-urlencoded

userId=8896&trainId=1001&fromIndex=1&toIndex=3&seatType=9

###############################################
# 完整流程测试
###############################################

### 21. 完整流程：初始化 -> 查询 -> 抢票 -> 查询配额
# Step 1: 初始化车次1003
POST http://localhost:8080/api/v1/tickets/initialize?trainId=1003
Accept: application/json

###

# Step 2: 查询库存
GET http://localhost:8080/api/v1/tickets/query?fromStationId=1&toStationId=5
Accept: application/json

###

# Step 3: 抢票
POST http://localhost:8080/api/v1/tickets/book
Content-Type: application/x-www-form-urlencoded

userId=7777&trainId=1001&fromIndex=0&toIndex=4&seatType=1

###

# Step 4: 查询剩余配额
GET http://localhost:8080/api/v1/tickets/quota?trainId=1003
Accept: application/json
